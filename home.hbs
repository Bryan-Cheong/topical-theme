{{!< default}}

<main class="gh-main gh-outer">
    <div class="gh-inner">

        {{!-- HERO SECTION --}}
        <section class="gh-home-hero">
            {{!-- Left Column: Text & CTA --}}
            <div class="gh-home-hero-left">
                <h1 class="gh-home-hero-title">
                    Turn Curiosity Into <span class="highlight-accent">Science, Robots</span> &amp; the Stars
                </h1>
                <a href="#browse-topics" class="gh-btn-accent">Browse Topics &rarr;</a>
                
                <p class="gh-home-hero-desc">
                    Hands-on STEM guides written for parents and kids - no PhD required. Discover robotics projects, astronomy activities, and science experiments that actually excite young minds.
                </p>
                <p class="gh-home-hero-desc">
                    Plus honest kit comparisons, budget-friendly picks, fun math ideas, book reviews, and skill-building guides - everything you need to nurture a curious child.
                </p>
            </div>

            {{!-- Right Column: Featured Posts Grid --}}
            <div class="gh-home-hero-right">
                <span class="gh-home-hero-label">Featured Posts</span>
                <div class="gh-home-hero-grid">
                    
                    {{!-- Fetch 4 featured posts --}}
                    {{#get "posts" filter="featured:true" limit="4" include="tags"}}
                        {{#foreach posts}}
                            <a href="{{url}}" class="gh-hero-card">
                                {{#if feature_image}}
                                    <div class="gh-hero-card-image">
                                        <img src="{{img_url feature_image size="m"}}" alt="{{title}}">
                                    </div>
                                {{/if}}

                                {{#if primary_tag}}
                                        <span class="gh-hero-card-tag">{{primary_tag.name}}</span>
                                {{/if}}

                                <div class="gh-hero-card-content">
                                    <h3 class="gh-hero-card-title">{{title}}</h3>
                                </div>
                            </a>
                        {{/foreach}}
                    {{/get}}

                </div>
            </div>
        </section>
    </div>

    {{!-- METRICS ROW --}}
    <div class="gh-home-metrics-wrapper">
        <div class="gh-inner">
            <section class="gh-home-metrics">
                
                <div class="gh-metric">
                    <span class="gh-metric-icon">📚</span>
                    <div class="gh-metric-content">
                        <h4 class="gh-metric-title">
                            {{!-- Fetches 1 post to get access to the total pagination count --}}
                            {{#get "posts" limit="1"}}
                                {{pagination.total}}
                            {{/get}}
                        </h4>
                        <p class="gh-metric-desc">Articles &amp; guides</p>
                    </div>
                </div>

                <div class="gh-metric">
                    <span class="gh-metric-icon">🧒</span>
                    <div class="gh-metric-content">
                        <h4 class="gh-metric-title">Ages 4-12</h4>
                        <p class="gh-metric-desc">And their parents</p>
                    </div>
                </div>

                <div class="gh-metric">
                    <span class="gh-metric-icon">🤷‍♂️</span>
                    <div class="gh-metric-content">
                        <h4 class="gh-metric-title">100%</h4>
                        <p class="gh-metric-desc">Non-technical parent friendly</p>
                    </div>
                </div>

            </section>
        </div>
    </div>

    <div class="gh-inner">

        {{!-- Browse by Topic - Editorial Style --}}
        <section class="gh-home-topics" id="browse-topics">
            <h2 class="gh-section-title">Browse by Topic</h2>

            <div class="gh-home-topics-grid">
                
                {{!-- 1. OUTER LOOP: Fetch the 3 main parent tags --}}
                {{#get "tags" filter="slug:[stem,robotics,astronomy]" include="count.posts" limit="all"}}
                    {{#foreach tags}}
                        
                        {{!-- Render the Card --}}
                        <article class="gh-home-topic-card">
                            <a class="gh-home-topic-link" href="{{url}}">
                                {{!-- Pull the feature image from the parent tag --}}
                                {{#if feature_image}}
                                    <figure class="gh-home-topic-image">
                                        <img src="{{img_url feature_image size="l"}}" alt="{{name}}">
                                    </figure>
                                {{/if}}
                                <div class="gh-home-topic-content">
                                    <h3 class="gh-home-topic-title">{{name}}</h3>
                                    <p class="gh-home-topic-excerpt">{{description}}</p>
                                </div>
                            </a>

                            {{!-- 2. INNER LOOP: Dynamically fetch subtopics for this specific card --}}
                            <nav class="gh-home-topic-subtopics">
                                {{#get "tags" filter="slug:~^'{{slug}}-'" limit="all" as |subtopics|}}
                                    {{#foreach subtopics}}
                                        {{!-- Go up two levels (../../) to grab the parent tag's slug for the URL --}}
                                        <a href="/{{../../slug}}/#{{slug}}">{{name}}</a>
                                    {{/foreach}}
                                {{/get}}
                            </nav>

                            <div class="gh-home-topic-footer">
                                <span class="gh-home-topic-meta">{{count.posts}} articles</span>
                            </div>
                        </article>

                    {{/foreach}}
                {{/get}}

            </div>
        </section>

        {{!-- FIND THE RIGHT STARTING POINT --}}
        <section class="gh-home-starting">
            <h2 class="gh-section-title">Find The Right Starting Point</h2>
            
            <div class="gh-starting-grid">
                
                {{!-- COLUMN 1: STEM --}}
                <div class="gh-subtopic-column">
                    {{#get "tags" filter="slug:[stem-science-experiments,stem-robotics-news]" limit="all"}}
                        {{#foreach tags}}
                            <a href="/stem/#{{slug}}" class="gh-starting-card">
                                {{#if feature_image}}
                                    <div class="gh-starting-image">
                                        <img src="{{img_url feature_image size="m"}}" alt="{{name}}">
                                    </div>
                                {{/if}}
                                <div class="gh-starting-content">
                                    <span class="gh-starting-tag gh-starting-pill">STEM</span>
                                    <div class="gh-starting-text-wrapper">
                                        <h4 class="gh-card-title">{{name}}</h4>
                                        <p class="gh-card-excerpt">{{description}}</p>
                                    </div>
                                </div>
                            </a>
                        {{/foreach}}
                    {{/get}}
                </div>

                {{!-- COLUMN 2: ROBOTICS --}}
                <div class="gh-subtopic-column">
                    {{#get "tags" filter="slug:[robotics-by-age,robotics-non-technical-parent]" limit="all"}}
                        {{#foreach tags}}
                            <a href="/robotics/#{{slug}}" class="gh-starting-card">
                                {{#if feature_image}}
                                    <div class="gh-starting-image">
                                        <img src="{{img_url feature_image size="m"}}" alt="{{name}}">
                                    </div>
                                {{/if}}
                                <div class="gh-starting-content">
                                    <span class="gh-starting-tag gh-starting-pill">Robotics</span>
                                    <div class="gh-starting-text-wrapper">
                                        <h4 class="gh-card-title">{{name}}</h4>
                                        <p class="gh-card-excerpt">{{description}}</p>
                                    </div>
                                </div>
                            </a>
                        {{/foreach}}
                    {{/get}}
                </div>

                {{!-- COLUMN 3: ASTRONOMY --}}
                <div class="gh-subtopic-column">
                    {{#get "tags" filter="slug:[astronomy-all-about-planets-and-more,astronomy-cloudy-nights-stories]" limit="all"}}
                        {{#foreach tags}}
                            <a href="/astronomy/#{{slug}}" class="gh-starting-card">
                                {{#if feature_image}}
                                    <div class="gh-starting-image">
                                        <img src="{{img_url feature_image size="m"}}" alt="{{name}}">
                                    </div>
                                {{/if}}
                                <div class="gh-starting-content">
                                    <span class="gh-starting-tag gh-starting-pill">Astronomy</span>
                                    <div class="gh-starting-text-wrapper">
                                        <h4 class="gh-card-title">{{name}}</h4>
                                        <p class="gh-card-excerpt">{{description}}</p>
                                    </div>
                                </div>
                            </a>
                        {{/foreach}}
                    {{/get}}
                </div>

            </div>
        </section>

    </div>
</main>
