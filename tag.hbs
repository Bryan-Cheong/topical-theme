{{!< default}}

{{!-- 1. COVER IMAGE LOGIC --}}
{{#tag}}
    {{#if feature_image}}
        <section class="gh-cover gh-outer">
            <img class="gh-cover-image"
                srcset="{{img_url feature_image size="s"}} 300w,
                        {{img_url feature_image size="m"}} 720w,
                        {{img_url feature_image size="l"}} 960w,
                        {{img_url feature_image size="xl"}} 1200w,
                        {{img_url feature_image size="xxl"}} 2000w"
                sizes="100vw" src="{{img_url feature_image size="xl"}}" alt="{{name}}">
            <div class="gh-cover-content">
                <h1 class="gh-cover-title">{{name}}</h1>
                {{#if description}}
                    <p class="gh-cover-description">{{description}}</p>
                {{/if}}
            </div>
        </section>
    {{/if}}
{{/tag}}

<main class="gh-main gh-outer">
    <div class="gh-inner">
        {{#tag}}
            {{!-- 2. STANDARD PAGEHEAD LOGIC --}}
            {{#unless feature_image}}
                {{!-- {{#match slug "!~" "stem|robotics|astronomy"}} --}}
                    <section class="gh-pagehead">
                        <h1 class="gh-pagehead-title">{{name}}</h1>
                        {{#if description}}
                            <div class="gh-pagehead-description">{{description}}</div>
                        {{/if}}
                    </section>
                {{!-- {{/match}} --}}
            {{/unless}}

            {{!-- 3. THE DYNAMIC TOPIC AUTOMATION --}}
            {{!-- Fetch any tags that start with this current tag's slug --}}
            {{#get "tags" filter="slug:~^'{{slug}}-'" limit="all" as |subtopics|}}
                
                {{#if subtopics}}
                    {{!-- This is a Topic Page. Render the subtopics --}}
                    {{#foreach subtopics}}

                        {{!-- DEBUG BLOCK: See what Handlebars is building --}}
                        {{!-- <div style="font-size: 11px; color: red; border: 1px solid red; padding: 6px; margin: 16px 0; background: #fff0f0;">
                            <strong>DEBUG - Section Generator:</strong><br>
                            Section ID: <code>id="{{slug}}"</code><br>
                            Section Title: <code>{{name}}</code><br>
                            Fetching posts with filter: <code>tag:{{slug}}</code>
                        </div> --}}

                        {{!-- The Dynamic Section Container --}}
                        <section id="{{slug}}" class="gh-subtopic-section">
                            <h2 class="gh-subtopic-title">{{name}}</h2>
                            
                            {{!-- Fetch the posts for THIS specific subtopic --}}
                            {{#get "posts" filter="tag:{{slug}}" limit="12" include="tags,authors"}}
                                {{#if posts}}
                                    <div class="gh-topic-content gh-topic-grid">
                                        {{#foreach posts}}
                                            {{> "loop-grid" has_large_post=true}}
                                        {{/foreach}}
                                    </div>
                                {{else}}
                                    <p class="gh-subtopic-empty">No posts yet in this category.</p>
                                {{/if}}
                            {{/get}}
                        </section>
                    {{/foreach}}

                    {{!-- Topic Newsletter at the bottom of the Topic Page --}}
                    {{> "topic-newsletter"}}

                {{else}}
                    {{!-- This is a non-topic tag page. Show the standard feed --}}
                    
                    {{!-- DEBUG BLOCK: Confirming the fallback --}}
                    {{!-- <div style="font-size: 11px; color: blue; border: 1px solid blue; padding: 6px; margin: 16px 0; background: #f0f8ff;">
                        <strong>DEBUG - Standard Feed:</strong><br>
                        No subtopics found for '{{../slug}}'. Falling back to standard post grid.
                    </div> --}}

                    <div class="gh-topic gh-topic-grid">
                        <div class="gh-topic-content gh-feed">
                            {{!-- 
                                Go up two levels (../../) to escape the get helper 
                                and grab the default posts array loaded for this page 
                            --}}
                            {{#foreach ../../posts}}
                                {{> "loop-grid"}}
                            {{/foreach}}
                        </div>
                    </div>
                {{/if}}

            {{/get}}
        {{/tag}}
    </div>
</main>
