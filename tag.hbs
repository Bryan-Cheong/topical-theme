{{!< default}}

{{#tag}}
    {{#if feature_image}}
        <section class="gh-cover gh-outer">
            <img
                class="gh-cover-image"
                srcset="{{img_url feature_image size="s"}} 300w,
                        {{img_url feature_image size="m"}} 720w,
                        {{img_url feature_image size="l"}} 960w,
                        {{img_url feature_image size="xl"}} 1200w,
                        {{img_url feature_image size="xxl"}} 2000w"
                sizes="100vw"
                src="{{img_url feature_image size="xl"}}"
                alt="{{name}}"
            >

            <div class="gh-cover-content">
                <h1 class="gh-cover-title">{{name}}</h1>

                {{#if description}}
                    <p class="gh-cover-description">{{description}}</p>
                {{/if}}
            </div>
        </section>
    {{/if}}
{{/tag}}

<main class="gh-main gh-outer">
    <div class="gh-inner">
        {{#tag}}
            {{#unless feature_image}}
                {{#match slug "!~" "stem|robotics|astronomy"}}
                    <section class="gh-pagehead">
                        <h1 class="gh-pagehead-title">{{name}}</h1>

                        {{#if description}}
                            <div class="gh-pagehead-description">{{description}}</div>
                        {{/if}}
                    </section>
                {{/match}}
            {{/unless}}

            {{!-- STEM Topic - One Pager with Subtopic Sections --}}
            {{#match slug "stem"}}
                {{!-- 1. Robotics News --}}
                <section id="stem-robotics-news" class="gh-subtopic-section">
                    <h2 class="gh-subtopic-title">Robotics News</h2>
                    {{#get "posts" filter="tag:hash-subtopic-robotics-news" limit="6" include="tags,authors"}}
                        {{#if posts}}
                            <div class="gh-topic-content gh-topic-grid">
                                {{#foreach posts}}
                                    {{> "loop-grid" has_large_post=true}}
                                {{/foreach}}
                            </div>
                        {{else}}
                            <p class="gh-subtopic-empty">No posts yet in this category.</p>
                        {{/if}}
                    {{/get}}
                </section>

                {{!-- 2. Science Experiments --}}
                <section id="stem-science-experiments" class="gh-subtopic-section">
