        {{!-- 4. STANDARD FEED: The "Double Filter" Logic --}}
        {{!-- Filter 1: Is this tag NOT 'stem'? --}}
        {{#match tag.slug "!=" "stem"}}
            
            {{!-- Filter 2: Is this tag NOT 'robotics'? --}}
            {{#match tag.slug "!=" "robotics"}}

                {{!-- Filter 3: Is this tag NOT 'astronomy'? --}}
                {{#match tag.slug "!=" "astronomy"}}
                
                    {{!-- Success! It is neither. Show the posts. --}}
                    <div class="gh-topic gh-topic-grid">
                        <div class="gh-topic-content gh-feed">
                            {{#foreach posts}}
                                {{> "loop-grid"}}
